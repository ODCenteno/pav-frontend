# Strapi CMS endpoint (default: http://localhost:1337)
STRAPI_URL="http://localhost:1337"

# Read-only API token from Strapi admin → Settings → API Tokens
# Required in production; optional in development (the dev fallback uses local data).
STRAPI_TOKEN=""

# Enable the local data fallback when Strapi is unreachable.
# Default: true in dev (`astro dev`), false in production builds.
# Set explicitly to override (true|false).
# STRAPI_USE_DEV_FALLBACK="true"

# Legacy Google Sheets endpoint (kept for the old import path; the new Strapi
# migration is the primary data source). Safe to leave blank.
API_LIST_URL=""

# Default locale for the site. Used by Astro's i18n routing.
PUBLIC_DEFAULT_LOCALE="es-MX"

# ─── CMS rebuild webhook ─────────────────────────────────────────────────────
# Set in BOTH this frontend and the Strapi backend (shared between them).
# Strapi lifecycle hooks POST to /api/revalidate with X-Webhook-Secret; the
# frontend then calls CF_PAGES_DEPLOY_HOOK_URL to trigger a Cloudflare rebuild.
#
# Get CF_PAGES_DEPLOY_HOOK_URL from:
#   Cloudflare dashboard → Workers & Pages → pav-frontend → Settings
#     → Build & deployments → Deploy hooks → Add hook
REVALIDATE_WEBHOOK_SECRET=""
CF_PAGES_DEPLOY_HOOK_URL=""
