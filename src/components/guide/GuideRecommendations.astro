---
import "./guideRecommendations.css";
import SvgIcon from "../icons/SvgIcon.astro";

interface Props {
  data: {
    title: { es: string; en: string };
    items: { es: string[]; en: string[] };
  };
  locale?: string;
}

const { data, locale = "es" } = Astro.props;
const lang = locale?.startsWith("en") ? "en" : "es";
const items = data.items[lang] || [];
---

<section class="guide-recommendations section-padding">
  <div class="container">
    <header class="guide-recommendations__header">
      <h2 class="guide-recommendations__title">{data.title[lang]}</h2>
    </header>
    <ul class="guide-recommendations__grid" role="list">
      {items.map((item, idx) => (
        <li class="guide-recommendations__item">
          <span class="guide-recommendations__num" aria-hidden="true">{String(idx + 1).padStart(2, "0")}</span>
          <p class="guide-recommendations__text">{item}</p>
          <span class="guide-recommendations__icon" aria-hidden="true">
            <SvgIcon name="leaf" class="guide-recommendations__icon-svg" />
          </span>
        </li>
      ))}
    </ul>
  </div>
</section>
