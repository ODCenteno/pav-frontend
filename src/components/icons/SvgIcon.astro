---
/**
 * SvgIcon.astro
 * Render de SVG inline sin SVGR.
 * - SSR-first
 * - Robusto en build/dev
 * - Permite class/aria-label
 */

export interface Props {
  name: "bookmark-outline" | "bookmark-filled" | "instagram" | "facebook" | "location" | "mail" | "phone" | "whatsapp" | "menu" | "close";
  class?: string;
  title?: string;
  ariaLabel?: string;
}

const { name, class: className = "", title, ariaLabel } = Astro.props;

// Mapa de iconos inline (puedes agregar más aquí)
const ICONS: Record<string, string> = {
  "bookmark-outline": `
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M7 3.5H17C18.1046 3.5 19 4.39543 19 5.5V21L12 17.25L5 21V5.5C5 4.39543 5.89543 3.5 7 3.5Z"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linejoin="round"
      />
    </svg>
  `,
  "bookmark-filled": `
    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
      <path d="M7 3.5H17C18.1046 3.5 19 4.39543 19 5.5V21L12 17.25L5 21V5.5C5 4.39543 5.89543 3.5 7 3.5Z"/>
    </svg>
  `,
  "instagram": `
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
  `,
  "facebook": `
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
  `,
  "location": `
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
  `,
  "mail": `
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
  `,
  "phone": `
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.79 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.81 12.81 0 0 0 .62 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.81 12.81 0 0 0 2.81.62A2 2 0 0 1 22 16.92z"></path></svg>
  `,
  "whatsapp": `
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L21 11.5z"></path></svg>
  `,
  "menu": `
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
  `,
  "close": `
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  `
};

const svg = ICONS[name];
if (!svg) {
  throw new Error(`SvgIcon: icon "${name}" not found`);
}

const a11yAttrs = ariaLabel ? `role="img" aria-label="${ariaLabel}"` : `aria-hidden="true"`;
---

<span class={className} set:html={svg} {...title ? { title } : {}} {...a11yAttrs ? {} : {}} />

<!-- Nota:
  - El <span> envuelve el svg inline.
  - El svg usa currentColor: controla color desde CSS (.bookmark-icon { color: ... }).
-->
