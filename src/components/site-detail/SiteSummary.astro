---
import "./siteSummary.css";

interface Props {
  description: string | undefined;
  labels: {
    about: string;
    directions: string;
    contact: string;
  };
  contactActions: {
    whatsapp?: string;
    phone?: string;
  };
  mapUrl?: string;
}

const { description, labels, contactActions, mapUrl } = Astro.props;
---

<section class="site-summary container">
  <div class="site-summary__grid">
    <div class="site-summary__main">
      <h2 class="site-summary__subtitle">{labels.about}</h2>
      <div class="site-summary__description">
        <p>{description}</p>
      </div>
    </div>

    <aside class="site-summary__sidebar">
      {mapUrl && (
        <div class="map-container">
          <iframe
            src={mapUrl}
            width="100%"
            height="250"
            class="map-iframe"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
            title={labels.about}
          ></iframe>
        </div>
      )}
      <div class="quick-actions-card">
        <button class="btn btn-primary btn-block mb-sm">
          {labels.directions}
        </button>
        {
          contactActions.whatsapp && (
            <a href={`https://wa.me/${contactActions.whatsapp}`} class="btn btn-outline btn-block" target="_blank">
              {labels.contact}
            </a>
          )
        }
      </div>
    </aside>

    <div class="site-summary__full-width">
      <slot />
    </div>
  </div>
</section>
