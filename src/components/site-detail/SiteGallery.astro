---
/**
 * Gallery section for the site-detail page.
 *
 * Owns the `<section>` shell and the localised title. Hands the actual grid
 * + lightbox to a `client:load` React island (`GalleryManager`), passing
 * an `images` prop instead of slot children. See `GalleryManager.tsx` for
 * why this pattern is required (slot children from Astro crash React SSR).
 */
import GalleryManager from "./GalleryManager.tsx";
import "./siteGallery.css";

interface Props {
  title: string;
  images: string[];
  noContainer?: boolean;
}

const { title, images, noContainer = false } = Astro.props;
const displayImages = images?.slice(0, 8) ?? [];
---

{displayImages.length > 0 && (
  <section class="site-gallery" class:list={{ container: !noContainer, "section-padding": !noContainer }}>
    <h2 class="site-gallery__title">{title}</h2>

    <GalleryManager
      client:load
      images={displayImages.map((src, i) => ({ src, alt: `${title} gallery ${i + 1}` }))}
    />
  </section>
)}
