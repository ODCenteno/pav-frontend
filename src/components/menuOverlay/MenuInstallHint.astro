---
/**
 * MenuInstallHint.astro — Always-visible offline install hint.
 *
 * Rendered as the last item in the mobile menu nav (below the EN/ES toggle).
 * Server-rendered, zero client JS — visible deterministically regardless of
 * whether the browser has fired `beforeinstallprompt`.
 *
 * Companion to InstallApp.astro (which provides the interactive CTA). This
 * block is the always-on informational companion so users without a
 * `beforeinstallprompt` event (Safari, Firefox, older browsers) still learn
 * that offline browsing is possible.
 */
import { useTranslations } from "@/i18n/utils";
import SvgIcon from "../icons/SvgIcon.astro";

const locale = Astro.currentLocale || "es";
const t = useTranslations(locale);
---

<aside class="menu-install-hint" aria-label={t("installHint.body")}>
  <span class="menu-install-hint__icon" aria-hidden="true">
    <SvgIcon name="download" class="menu-install-hint__icon-svg" />
  </span>
  <p class="menu-install-hint__body">{t("installHint.body")}</p>
</aside>
