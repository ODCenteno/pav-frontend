---
import "./hero.css";
import { Image } from "astro:assets";
// import img1 from "../../public/images/pav-01.jpg";
// import img2 from "../../public/images/pav-10.jpg";
// import img3 from "../../public/images/pav-11.jpg";
import { useTranslations } from "../../../i18n/utils";
import { navigation } from "@/utils/navigation";

const t = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale || "es";
---

<section class="hero section-padding">
  <div class="container hero-container">
    <div class="hero-content">
      <h1 data-key="hero_title" set:html={t("hero.title")} />
      <p data-key="hero_desc">{t("hero.desc")}</p>
      <div class="hero-actions">
        <a class="btn btn-accent" href={navigation.sites(locale)} data-key="hero_cta">{t("hero.cta")}</a></li>
      </div>
    </div>
    <div class="hero-images">
      <div class="hero-img-card img-1">
        <img src={"/images/PAV-Lanscape-Cueva.webp"} alt="Coast" loading="eager" />
      </div>
      <div class="hero-img-card img-2">
        <img src={"/images/pav-02.jpg"} alt="Nature" loading="eager" />
      </div>
      <div class="hero-img-card img-3">
        <img src={"/images/PAV-Lanscape-Fuga.webp"} alt="Landscape" loading="eager" />
      </div>
    </div>
  </div>
</section>
