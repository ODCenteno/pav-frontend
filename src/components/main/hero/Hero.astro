---
import "./hero.css";
import { useTranslations } from "../../../i18n/utils";
import { navigation } from "@/utils/navigation";
import type { HeroData } from "@/types/homepage.type";

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
const locale = Astro.currentLocale || "es";
const t = useTranslations(locale);
---

<section class="hero section-padding">
  <div class="container hero-container">
    <div class="hero-content">
      <h1 data-key="hero_title">
        {data.title}
        {data.titleHighlight && <span class="highlight-text">{data.titleHighlight}</span>}
      </h1>
      <p data-key="hero_desc">{data.description}</p>
      <div class="hero-actions">
        <a class="btn btn-accent" href={data.ctaLink || navigation.sites(locale)} data-key="hero_cta">{data.ctaLabel || t("hero.cta")}</a></li>
      </div>
    </div>
    <div class="hero-images">
      {data.images.map((img, i) => (
        <div class={`hero-img-card img-${i + 1}`}>
          <img src={img.url} alt={img.alt} loading="eager" />
        </div>
      ))}
    </div>
  </div>
</section>