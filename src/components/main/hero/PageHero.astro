---
import "./pageHero.css";
const { title, description } = Astro.props;
---

<section class="page-hero section-padding">
  <div class="container">
    <div class="page-hero__content">
      <h1 class="page-hero__title">{title}</h1>
      <p class="page-hero__description">{description}</p>
    </div>
  </div>
</section>
