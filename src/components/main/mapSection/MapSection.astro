---
import "./mapSection.css";
import MapView from "@/components/maps/MapView.tsx";
import type { MapSectionData } from "@/types/homepage.type";

interface ListingMarker {
  lat: number;
  lng: number;
  title: string;
  href: string;
  categoryColor: string;
}

interface Props {
  data: MapSectionData;
  listings?: ListingMarker[];
  locale?: string;
}

const { data, listings = [], locale = 'es' } = Astro.props;
---

<section class="map-section">
  <div class="map-full">
    <MapView
      client:only="react"
      markers={listings}
      center={data.centerPoint ? [data.centerPoint.lat, data.centerPoint.lng] : [25.512, -111.075]}
      zoom={data.zoom || 12}
      height={560}
    />
  </div>

  <div class="map-overlay">
    <div class="container">
      <div class="map-content-card">
        <h2 data-key="map_title">{data.title || 'Mapa del Destino'}</h2>
        <p class="map-description" data-key="map_desc">{data.description || 'Explora los puntos clave de Puerto Agua Verde y Rancho San Cosme.'}</p>
        <a href={data.buttonUrl || '#'} target="_blank" rel="noopener noreferrer" class="btn btn-accent">{data.buttonLabel || 'Ver Mapa en OpenStreetMap'}</a>
      </div>
    </div>
  </div>
</section>
