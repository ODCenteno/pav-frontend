---
import "./ctaSection.css";
import { useTranslations } from "../../../i18n/utils";

const t = useTranslations(Astro.currentLocale);
---

<section class="section-padding text-center">
  <div class="container">
    <h2 data-key="final_cta_title">{t("finalCta.title")}</h2>
    <p class="cta-description" data-key="final_cta_desc">{t("finalCta.desc")}</p>
    <a href="#" class="btn btn-primary" data-key="final_cta_btn">{t("finalCta.btn")}</a>
  </div>
</section>
