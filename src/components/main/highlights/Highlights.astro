---
import "./highlights.css";
import type { SectionHeader, HighlightCard } from "@/types/homepage.type";

interface Props {
  header: SectionHeader;
  items: HighlightCard[];
}

const { header, items } = Astro.props;
---

<section class="highlights section-padding">
  <div class="container">
    <div class="section-header">
      <h2 data-key="highlights_title">{header.title}</h2>
      <p class="highlights-subtitle" data-key="highlights_subtitle">{header.subtitle}</p>
    </div>
    <div class="highlights-layout">
      {items.slice(0, 3).map((card) => (
        <div class="review-card">
          <div class="card-img-container">
            <img src={card.image} alt={card.alt} />
          </div>
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>