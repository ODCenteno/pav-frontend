---
import CardMain from "../../cards/CardMain.astro";
import { useTranslations } from "../../../i18n/utils";
import type { Listing } from "../../../types/listing.type";

interface Props {
  listings: Listing[];
}

const { listings } = Astro.props as Props;

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);

const categories = [
  { id: "all", label: t("categories.all") },
  { id: "sites", label: t("sitesPage.filters.beaches") },
  { id: "restaurants", label: t("sitesPage.filters.food") },
  { id: "accommodation", label: t("sitesPage.filters.stay") },
  { id: "services", label: t("sitesPage.filters.services") },
  { id: "experiences", label: t("nav.experiences") }
];

const favEmpty = t("sitesPage.favoritesEmpty");
const filterEmpty = t("sitesPage.empty");
---

<section class="favorites-section section-padding" id="favorites-section">
  <div class="container">
    <div class="section-header">
      <h2 class="favorites-title">{t("gallery.title")}</h2>
      <p class="favorites-subtitle">{t("sitesPage.sections.favorites")}</p>
    </div>

    <!-- Category Chips for Favorites -->
    <div class="filter-container">
      <div class="filter-chips" id="favorite-chips">
        {categories.map(cat => (
          <button type="button" class="chip" data-category-filter={cat.id} class:list={{ active: cat.id === 'all' }}>
            {cat.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Favorites Carousel - All cards rendered server-side; CSS hides them by default; JS shows only favorites -->
    <div id="favorites-carousel-container" class="carousel-container favorites-empty">
      {listings.map((item) => (
        <div
          class="carousel-item favorite-card-wrapper"
          data-fav-id={String(item.id)}
          data-category={item.category?.slug || ""}
        >
          <CardMain item={item} currentLang={locale} />
        </div>
      ))}
    </div>

    <!-- Empty State - Hidden by default; JS shows it only when appropriate -->
    <div id="favorites-empty-state" class="empty-state" data-empty-text={favEmpty} data-filter-text={filterEmpty} style="display: none;">
      <div class="empty-state__content">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="empty-icon"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
        <p id="favorites-empty-text">{favEmpty}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .favorites-section {
    background-color: var(--color-bone);
    border-bottom: 1px solid var(--border-color);
  }

  /* Hide favorite cards by default; JS adds .is-favorite-visible to show them */
  .favorite-card-wrapper {
    display: none;
  }

  .favorite-card-wrapper.is-favorite-visible {
    display: block;
  }

  .favorites-empty .favorite-card-wrapper {
    /* No override: keep cards hidden until JS runs */
  }

  .favorites-title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-xs);
  }

  .favorites-subtitle {
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--text-sm);
  }

  .empty-state {
    padding: var(--space-xl) 0;
    text-align: center;
    border: 2px dashed var(--border-color);
    border-radius: var(--radius-lg);
    background: var(--white);
  }

  .empty-state__content {
    max-width: 400px;
    margin: 0 auto;
    color: var(--secondary-text);
  }

  .empty-icon {
    margin-bottom: var(--space-sm);
    opacity: 0.5;
  }

  .filter-container {
    text-align: center;
  }

  .carousel-container {
    display: flex;
    gap: var(--space-md);
    overflow-x: auto;
    padding: var(--space-sm) 0 0;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .carousel-container::-webkit-scrollbar { display: none; }

  .carousel-item {
    flex: 0 0 280px;
    scroll-snap-align: start;
  }

  @media (min-width: 768px) {
    .carousel-item {
      flex: 0 0 320px;
    }
  }
</style>

<script>
  import { getFavorites } from "../../../utils/favorites";

  function initFavoritesSection() {
    const section = document.getElementById("favorites-section");
    if (!section) return;

    const carousel = document.getElementById("favorites-carousel-container");
    const emptyState = document.getElementById("favorites-empty-state");
    const emptyText = document.getElementById("favorites-empty-text");
    const cardWrappers = section.querySelectorAll<HTMLElement>(".favorite-card-wrapper");
    const chips = section.querySelectorAll<HTMLElement>("[data-category-filter]");

    const favEmptyMsg = emptyState?.dataset.emptyText || "";
    const filterEmptyMsg = emptyState?.dataset.filterText || "";

    let activeFilter = "all";

    function updateFavorites() {
      const favorites = getFavorites();
      const favSet = new Set(favorites);
      let visibleCount = 0;

      cardWrappers.forEach((el) => {
        const id = el.getAttribute("data-fav-id") || "";
        const category = el.getAttribute("data-category") || "";
        const isFav = id !== "" && favSet.has(id);
        const matchesFilter = activeFilter === "all" || category === activeFilter;

        if (isFav && matchesFilter) {
          el.classList.add("is-favorite-visible");
          visibleCount++;
        } else {
          el.classList.remove("is-favorite-visible");
        }
      });

      const noFavoritesAtAll = favorites.length === 0;
      const filterHasNoMatches = visibleCount === 0 && favorites.length > 0;
      const showEmpty = noFavoritesAtAll || filterHasNoMatches;

      if (emptyState) {
        emptyState.style.display = showEmpty ? "block" : "none";
      }
      if (emptyText) {
        emptyText.textContent = noFavoritesAtAll ? favEmptyMsg : filterEmptyMsg;
      }
      if (carousel) {
        carousel.classList.toggle("favorites-empty", visibleCount === 0);
      }
    }

    // Filter chip handlers
    chips.forEach(chip => {
      chip.addEventListener("click", () => {
        activeFilter = chip.getAttribute("data-category-filter") || "all";
        chips.forEach(c => c.classList.remove("active"));
        chip.classList.add("active");
        updateFavorites();
      });
    });

    // Sync when favorites change in another component
    window.addEventListener("favorites-updated", updateFavorites);

    // Run on init
    updateFavorites();
  }

  document.addEventListener("DOMContentLoaded", initFavoritesSection);
  document.addEventListener("astro:page-load", initFavoritesSection);
</script>
