---
import "./quickFacts.css";
import type { SectionHeader, QuickFact } from "@/types/homepage.type";

interface Props {
  header: SectionHeader;
  items: QuickFact[];
  images: string[];
}

const { header, items, images } = Astro.props;

const [image1, image2] = images;
---

<section class="quick-facts section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="quick-facts__title">{header.title}</h2>
      <p class="quick-facts__subtitle">{header.subtitle}</p>
    </div>

    <div class="quick-facts__bento">
      <div class="quick-facts__card fact-accent-1">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{items[0]?.title}</h3>
          <div class="quick-facts__card-value">{items[0]?.value}</div>
          <p class="quick-facts__card-desc">{items[0]?.description}</p>
        </div>
      </div>

      <div class="quick-facts__card">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{items[1]?.title}</h3>
          <div class="quick-facts__card-value">{items[1]?.value}</div>
          <p class="quick-facts__card-desc">{items[1]?.description}</p>
        </div>
      </div>

      <div class="quick-facts__image-box">
        {image1 && <img src={image1} alt="Puerto Agua Verde landscape" />}
      </div>

      <div class="quick-facts__card">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{items[2]?.title}</h3>
          <div class="quick-facts__card-value">{items[2]?.value}</div>
          <p class="quick-facts__card-desc">{items[2]?.description}</p>
        </div>
      </div>

      <div class="quick-facts__card">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{items[3]?.title}</h3>
          <div class="quick-facts__card-value">{items[3]?.value}</div>
          <p class="quick-facts__card-desc">{items[3]?.description}</p>
        </div>
      </div>

      <div class="quick-facts__card">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{items[4]?.title}</h3>
          <div class="quick-facts__card-value">{items[4]?.value}</div>
          <p class="quick-facts__card-desc">{items[4]?.description}</p>
        </div>
      </div>

      <div class="quick-facts__image-box">
        {image2 && <img src={image2} alt="Local details" />}
      </div>

      <div class="quick-facts__card fact-accent-2 wide">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{items[5]?.title}</h3>
          <div class="quick-facts__card-value">{items[5]?.value}</div>
          <p class="quick-facts__card-desc">{items[5]?.description}</p>
        </div>
      </div>
    </div>
  </div>
</section>