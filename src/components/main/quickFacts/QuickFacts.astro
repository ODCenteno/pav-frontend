---
import "./quickFacts.css";
import { useTranslations } from "../../../i18n/utils";

const locale = Astro.currentLocale ?? "es";
const t = useTranslations(locale);

const quickFactsItems = t("quickFacts.items") as any[];

// Current images to use
const image1 = "/images/pav-01.jpg";
const image2 = "/images/pav-04.jpg";
---

<section class="quick-facts section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="quick-facts__title">{t("quickFacts.title")}</h2>
      <p class="quick-facts__subtitle">{t("quickFacts.subtitle")}</p>
    </div>

    <div class="quick-facts__bento">
      <!-- Row 1: Fact 1, Image 1, Fact 2 -->
      <div class="quick-facts__card fact-accent-1">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{quickFactsItems[0].title}</h3>
          <div class="quick-facts__card-value">{quickFactsItems[0].value}</div>
          <p class="quick-facts__card-desc">{quickFactsItems[0].desc}</p>
        </div>
      </div>

      <div class="quick-facts__card">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{quickFactsItems[1].title}</h3>
          <div class="quick-facts__card-value">{quickFactsItems[1].value}</div>
          <p class="quick-facts__card-desc">{quickFactsItems[1].desc}</p>
        </div>
      </div>

      <div class="quick-facts__image-box">
        <img src={image1} alt="Puerto Agua Verde landscape" />
      </div>

      <!-- Row 2: Fact 3, Fact 4, Fact 5 -->
      <div class="quick-facts__card">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{quickFactsItems[2].title}</h3>
          <div class="quick-facts__card-value">{quickFactsItems[2].value}</div>
          <p class="quick-facts__card-desc">{quickFactsItems[2].desc}</p>
        </div>
      </div>

      <div class="quick-facts__card">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{quickFactsItems[3].title}</h3>
          <div class="quick-facts__card-value">{quickFactsItems[3].value}</div>
          <p class="quick-facts__card-desc">{quickFactsItems[3].desc}</p>
        </div>
      </div>

      <div class="quick-facts__card">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{quickFactsItems[4].title}</h3>
          <div class="quick-facts__card-value">{quickFactsItems[4].value}</div>
          <p class="quick-facts__card-desc">{quickFactsItems[4].desc}</p>
        </div>
      </div>

      <!-- Row 3: Image 2, Fact 6 (Wide) -->
      <div class="quick-facts__image-box">
        <img src={image2} alt="Local details" />
      </div>

      <div class="quick-facts__card fact-accent-2 wide">
        <div class="quick-facts__card-content">
          <h3 class="quick-facts__card-title">{quickFactsItems[5].title}</h3>
          <div class="quick-facts__card-value">{quickFactsItems[5].value}</div>
          <p class="quick-facts__card-desc">{quickFactsItems[5].desc}</p>
        </div>
      </div>
    </div>
  </div>
</section>
