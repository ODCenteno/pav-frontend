---
import "./categories.css";
import type { Listing } from "../../../types/listing.type";
import type { LocalizedString } from "../../../types/i18n.type";
import { useTranslations } from "../../../i18n/utils";

import CategoryFilter from "@/components/main/categories/CategoryFilter.tsx";
import CardMain from "@/components/cards/CardMain.astro";

// 1) Locale seguro (Astro.currentLocale puede ser undefined en tipos)
const locale = Astro.currentLocale ?? Astro.defaultLocale ?? "es";

// 2) Traductor SSR
const t = useTranslations(locale);

// Helper local para LocalizedString (por si category.name existe)
function getLocalizedText(value?: LocalizedString, loc: string = "es"): string {
  if (!value) return "";
  const isEn = loc.toLowerCase().startsWith("en");
  const key = isEn ? "en" : "es";
  const v = (value as any)?.[key] ?? (value as any)?.es ?? (value as any)?.en;
  return typeof v === "string" ? v : "";
}

// 3) Fetch SSR (defensivo)
let categoryData: Listing[] = [];
try {
  const listingAPI = await fetch(`${import.meta.env.API_LIST_URL}?status=published`);
  const listingJson = listingAPI.ok ? await listingAPI.json() : { data: [] };
  categoryData = Array.isArray(listingJson?.data) ? listingJson.data : [];
} catch {
  categoryData = [];
}

// 4) Construir categorías dinámicas (id + label traducible)
// - Si viene `item.category?.name` úsalo (mejor UX)
// - Si no, fallback a usar el id tal cual (y luego lo mapeamos)
const categoryMap = new Map<string, string>();

for (const item of categoryData) {
  const id = item.categoryId;
  if (!id) continue;

  const labelFromJoin = item.category?.name ? getLocalizedText(item.category.name as any, locale) : "";
  const label = labelFromJoin || id; // fallback mínimo

  if (!categoryMap.has(id)) categoryMap.set(id, label);
}

// Ordenar alfabéticamente por label para UI estable
const categories = Array.from(categoryMap.entries())
  .map(([id, label]) => ({ id, label }))
  .sort((a, b) => a.label.localeCompare(b.label, locale));

// 5) Strings UI (SSR)
const translations = {
  noResults: t("gallery.noResults"),
  viewAll: t("gallery.viewAll"),
  all: t("categories.all"),
};

// 6) viewAllHref seguro por locale (sin error de undefined)
const isEnglish = locale.toLowerCase().startsWith("en");
const viewAllHref = isEnglish ? "/en-US/explore" : "/explorar";
---

<section class="destinations section-padding">
  <div class="container">
    <div class="section-header categories-header">
      <h2>{t("gallery.title")}</h2>
      <p class="categories-subtitle">{t("gallery.desc")}</p>

      <CategoryFilter client:visible locale={locale} translations={translations} categories={categories} viewAllHref={viewAllHref} containerSelector="#category-carousel-container" itemSelector="[data-category]" />

      <!-- SSR-first: cards renderizadas en servidor -->
      <div id="category-carousel-container" class="carousel-container">
        {categoryData.map((item) => <CardMain item={item} currentLang={locale} />)}
      </div>
    </div>
  </div>
</section>
