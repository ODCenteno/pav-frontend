---
import "./destinations.css";
import type { SectionHeader, DestinationStory } from "@/types/homepage.type";

interface Props {
  header: SectionHeader;
  items: DestinationStory[];
}

const { header, items } = Astro.props;
---

<section class="stories section-padding">
  <div class="container">
    <div class="section-header">
      <h2 data-key="stories_title">{header.title}</h2>
      <p class="stories-subtitle" data-key="stories_subtitle">{header.subtitle}</p>
    </div>
    <div class="stories-layout">
      {items.slice(0, 2).map((story) => (
        <article class="featured-story">
          <div class="story-img">
            <img src={story.image} alt={story.alt} />
          </div>
          <div class="story-content">
            <h3>{story.title}</h3>
            <p class="excerpt">{story.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>