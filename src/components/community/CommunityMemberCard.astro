---
import "./communityMemberCard.css";
import type { CommunityMember } from "@/types/community.type";
import { useTranslations } from "@/i18n/utils";
import { navigation } from "@/utils/navigation";

interface Props {
  member: CommunityMember;
  locale: string;
}

const { member, locale } = Astro.props;
const t = useTranslations(locale);

const platformIcons: Record<string, string> = {
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`,
  facebook: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>`,
  tiktok: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>`,
  web: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>`,
};

function getSocialUrl(platform: string, handle: string, url?: string): string {
  if (url) return url;
  switch (platform) {
    case 'whatsapp': return `https://wa.me/${handle.replace(/\D/g, '')}`;
    case 'instagram': return `https://instagram.com/${handle.replace('@', '')}`;
    case 'facebook': return `https://facebook.com/${handle}`;
    default: return '#';
  }
}

const localityLabel = member.locality ? t(`communityPage.localityLabels.${member.locality}`) : null;
const listingHrefs = member.listingSlugs.map(slug => navigation.siteDetail(slug, locale));
---
<article class="community-member-card">
  <div class="community-member-card__photo-container">
    {member.photo ? (
      <img
        src={member.photo}
        alt={member.name}
        class="community-member-card__photo"
        loading="lazy"
      />
    ) : (
      <div class="community-member-card__photo community-member-card__photo--placeholder">
        {member.name.charAt(0)}
      </div>
    )}
  </div>

  <div class="community-member-card__content">
    {localityLabel && (
      <span class="community-member-card__locality">{localityLabel}</span>
    )}

    <h3 class="community-member-card__name">{member.name}</h3>

    {member.role && (
      <p class="community-member-card__role">{member.role}</p>
    )}

    {member.pullQuote && (
      <blockquote class="community-member-card__quote">
        <p>{member.pullQuote}</p>
      </blockquote>
    )}

    {member.legacyNote && (
      <span class="community-member-card__legacy">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
        {member.legacyNote}
      </span>
    )}

    {member.relatedMembers && member.relatedMembers.length > 0 && (
      <div class="community-member-card__family">
        <span class="community-member-card__family-label">{t("communityPage.familyLabel")}</span>
        <div class="community-member-card__family-chips">
          {member.relatedMembers.map(rm => (
            <span class="community-member-card__family-chip">
              {rm.name}
              {rm.legacyNote && <span class="community-member-card__family-gen"> · {rm.legacyNote}</span>}
            </span>
          ))}
        </div>
      </div>
    )}

    {member.bio && (
      <p class="community-member-card__bio">{member.bio}</p>
    )}

    <div class="community-member-card__footer">
      {member.social && member.social.length > 0 ? (
        <div class="community-member-card__social">
          {member.social.map(link => (
            <a
              href={getSocialUrl(link.platform, link.handle || '', link.url)}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${link.platform} ${link.handle || ''}`}
              class={`community-member-card__social-link community-member-card__social-link--${link.platform}`}
              set:html={platformIcons[link.platform] || platformIcons.web}
            />
          ))}
        </div>
      ) : (
        <span class="community-member-card__no-social">{t("communityPage.noSocial")}</span>
      )}

      {listingHrefs.length > 0 && (
        <a
          href={listingHrefs[0]}
          class="community-member-card__cta"
        >
          {t("communityPage.viewListing")}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
      )}
    </div>
  </div>
</article>