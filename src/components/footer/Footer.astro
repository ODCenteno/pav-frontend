---
import "@/components/footer/footer.css";
import { useTranslations } from "../../i18n/utils";
import SvgIcon from "../icons/SvgIcon.astro";
import { navigation } from "@/utils/navigation";
import { getSiteSettings } from "@/lib/cms";
import { getSiteContents } from "@/lib/cms";

const locale = Astro.currentLocale || "es";
const t = useTranslations(locale);

const [settings, footerContents] = await Promise.all([
  getSiteSettings(),
  getSiteContents(["footer-about", "footer-contact"], locale),
]);

const footerAbout = footerContents[0];
const footerContact = footerContents[1];

const aboutTitle = footerAbout?.title?.[locale === "en" ? "en" : "es"] || t("footer.aboutTitle");
const aboutText = footerAbout?.text?.[locale === "en" ? "en" : "es"] || t("footer.desc");
const aboutThanks = footerAbout?.extraData?.thanks?.[locale === "en" ? "en" : "es"] || t("footer.thanks");
const aboutRights = footerAbout?.extraData?.rights?.[locale === "en" ? "en" : "es"] || t("footer.rights");
const aboutLegal = footerAbout?.extraData?.legal?.[locale === "en" ? "en" : "es"] || t("footer.legal");

const contactTitle = footerContact?.title?.[locale === "en" ? "en" : "es"] || t("footer.contactTitle");
const contactNote = footerContact?.extraData?.note?.[locale === "en" ? "en" : "es"] || t("footer.note");

const currentYear = new Date().getFullYear();
---

<footer class="footer-main">
  <div class="container footer-grid">
    <div class="footer-col footer-about" aria-label="About the site">
      <h3 class="footer__about-title" data-key="footer_about_title">
        {aboutTitle}
      </h3>
      <p data-key="footer_desc">{aboutText}</p>
      <p data-key="footer_thanks">{aboutThanks}</p>
    </div>
    <div class="footer-col" aria-label="Quick links">
      <h3 class="footer_title" data-key="footer_title">{t("footer.title")}</h3>
      <ul class="footer__list">
        <li><a class="footer-link" href={navigation.experiences(locale)} data-key="footer_link_home">{t("footer.experiences")}</a></li>
        <li><a class="footer-link" href={navigation.homeAnchor("categories", locale)} data-key="footer_link_categories">{t("footer.categories")}</a></li>
        <li><a class="footer-link" href={navigation.homeAnchor("destinations", locale)} data-key="footer_link_destinations">{t("footer.destinations")}</a></li>
        <li><a class="footer-link" href={navigation.homeAnchor("highlights", locale)} data-key="footer_link_highlights">{t("footer.highlights")}</a></li>
        <li><a class="footer-link" href={navigation.homeAnchor("map", locale)} data-key="footer_link_map">{t("footer.map")}</a></li>
        <li><a class="footer-link" href={navigation.guide(locale)} data-key="footer_link_guide">{t("nav.guide")}</a></li>
      </ul>
    </div>

    <section class="footer-col" aria-label="Contact and social">
      <h3 class="footer-heading" data-key="footer_contact_title">{contactTitle}</h3>

      <ul class="footer-social">
        <li>
          <a class="footer-link" href={settings.social.instagram} target="_blank" rel="noopener noreferrer">
            <SvgIcon name="instagram" class="footer-icon" />
            <span data-key="footer_instagram">Instagram</span>
          </a>
        </li>
        <li>
          <a class="footer-link" href={settings.social.facebook} target="_blank" rel="noopener noreferrer">
            <SvgIcon name="facebook" class="footer-icon" />
            <span data-key="footer_facebook">Facebook</span>
          </a>
        </li>
        <li>
          <a class="footer-link" href={settings.social.googleMaps} target="_blank" rel="noopener noreferrer">
            <SvgIcon name="location" class="footer-icon" />
            <span data-key="footer_location">Location</span>
          </a>
        </li>
      </ul>

      <div class="footer-contact">
        <a class="footer-contactItem footer-link" href={`mailto:${settings.contact.email}`}>
          <SvgIcon name="mail" class="footer-icon" />
          <span>{settings.contact.email}</span>
        </a>

        <a class="footer-contactItem footer-link" href={`tel:${settings.contact.phoneRaw}`}>
          <SvgIcon name="phone" class="footer-icon" />
          <span>{settings.contact.phone}</span>
        </a>

        <a class="footer-contactItem footer-link" href={`https://wa.me/${settings.contact.whatsapp}`} target="_blank" rel="noopener noreferrer">
          <SvgIcon name="whatsapp" class="footer-icon" />
          <span data-key="footer_whatsapp">WhatsApp</span>
        </a>
      </div>

      <p class="footer-note" data-key="footer_note">{contactNote}</p>
    </section>
  </div>
  <div class="footer-bottom">
    <p class="footer-rights" data-key="footer_rights">© {currentYear} {settings.metadata.siteName}. {aboutRights}</p>

    <a class="footer-legal footer-link" href={navigation.legal("privacy-notice", locale)} data-key="footer_legal">{aboutLegal}</a>
  </div>
</footer>