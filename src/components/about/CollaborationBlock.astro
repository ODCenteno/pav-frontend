---
import "./collaborationBlock.css";

import { useTranslations } from "@/i18n/utils";

interface Props {
  data?: {
    title: string;
    desc: string;
    btnPrimary: string;
    btnSecondary: string;
    links?: {
      primary: string;
      secondary: string;
    };
  };
  locale?: string;
}

const { data, locale = "es" } = Astro.props;
const t = useTranslations(locale);

const title = data?.title || t("aboutPage.collab.title");
const desc = data?.desc || t("aboutPage.collab.desc");
const btnPrimary = data?.btnPrimary || t("aboutPage.collab.btnPrimary");
const btnSecondary = data?.btnSecondary || t("aboutPage.collab.btnSecondary");
const links = data?.links || { primary: "#", secondary: "#" };
---

<section class="collaboration-block section-padding">
  <div class="container">
    <div class="collaboration-block__content">
      {title && <h2 class="collaboration-block__title">{title}</h2>}
      {desc && <p class="collaboration-block__description">{desc}</p>}
      <div class="collaboration-block__actions">
        {btnPrimary && <a href={links.primary} class="btn btn-primary">{btnPrimary}</a>}
        {btnSecondary && <a href={links.secondary} class="btn btn-outline">{btnSecondary}</a>}
      </div>
    </div>
  </div>
</section>
