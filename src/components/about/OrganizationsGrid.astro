---
import OrgCard from "./OrgCard.astro";
import type { Organization } from "../../types/about.type";
import "./organizationsGrid.css";
import { useTranslations } from "@/i18n/utils";

interface Props {
  title?: string;
  description?: string;
  organizations?: Organization[];
  locale: string;
}

const { title, description, organizations = [], locale = "es" } = Astro.props;
const t = useTranslations(locale);

const displayTitle = title || t("aboutPage.organizations.title");
const displayDescription = description || t("aboutPage.organizations.desc");
---

<section class="orgs-grid section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="orgs-grid__title">{displayTitle}</h2>
      {displayDescription && <p class="orgs-grid__description">{displayDescription}</p>}
    </div>

    <div class="orgs-grid__list">
      {Array.isArray(organizations) && organizations.map((org) => <OrgCard org={org} locale={locale} />)}
    </div>
  </div>
</section>
