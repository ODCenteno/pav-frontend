---
import "./aboutIntro.css";

import { useTranslations } from "@/i18n/utils";

interface Props {
  data?: {
    title: string;
    text: string;
  };
  locale?: string;
}

const { data, locale = "es" } = Astro.props;
const t = useTranslations(locale);

const title = data?.title || t("aboutPage.intro.title");
const text = data?.text || t("aboutPage.intro.text");
---

<section class="about-intro section-padding">
  <div class="about-intro__grid container">
    <div class="about-intro__header">
      {title && <h2 class="about-intro__title">{title}</h2>}
    </div>
    <div class="about-intro__content">
      {text && <p class="about-intro__text">{text}</p>}
    </div>
  </div>
</section>
