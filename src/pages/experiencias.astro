---
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroPage from "@/components/main/hero/HeroPage.astro";
import ExpFeatured from "@/components/main/experiences/ExpFeatured.astro";
import ExpCTA from "@/components/main/experiences/ExpCTA.astro";
import { useTranslations } from "@/i18n/utils";
import { getListingsWithFallback, getExperiencesPageWithFallback, toStrapiLocale} from "@/lib/cms";
import { navigation } from "@/utils/navigation";
import { assertBuildData } from "@/lib/buildGuard";

const locale = toStrapiLocale(Astro.currentLocale || "es");
const t = useTranslations(locale);

const [experiencesPage, allListings] = await Promise.all([
  getExperiencesPageWithFallback(locale),
  getListingsWithFallback(locale),
]);

assertBuildData(allListings, "/experiencias", locale);

const featuredExperiences = allListings
  .filter((item) => item.category?.slug === "experiences")
  .slice(0, 3);

const heroBgImage = experiencesPage?.hero.images?.[0]?.url || "/images/pav-landscape-12.webp";
const heroTitle = experiencesPage?.hero.title || t("experiencesPage.heroTitle");
const heroDesc = experiencesPage?.hero.description || t("experiencesPage.heroDesc");
const introTitle = experiencesPage?.introHeader?.title || t("experiencesPage.introTitle");
const introDesc = experiencesPage?.introHeader?.subtitle || t("experiencesPage.introDesc");
const featuredTitle = experiencesPage?.featuredHeader?.title || t("experiencesPage.featuredTitle");
const featuredDesc = experiencesPage?.featuredHeader?.subtitle;
---

<BaseLayout
  siteTitle={t("page.experiences.siteTitle")}
  ogTitle={t("page.experiences.ogTitle")}
  siteDescription={t("page.experiences.siteDescription")}
  ogDescription={t("page.experiences.ogDescription")}
>
  <HeroPage
    slot="Hero"
    title={heroTitle}
    description={heroDesc}
    backgroundImage={heroBgImage}
  />

  <section class="experiences-intro section-padding">
    <div class="container text-center">
      <h2>{introTitle}</h2>
      <p class="max-w-700">{introDesc}</p>
    </div>
  </section>

  {featuredExperiences.length > 0 && (
    <section class="experiences-featured-header">
      <div class="container text-center">
        <h2>{featuredTitle}</h2>
        {featuredDesc && <p class="max-w-700">{featuredDesc}</p>}
      </div>
    </section>
  )}

  <div class="experiences-list">
    {featuredExperiences.map((exp, index) => (
      <ExpFeatured
        experience={exp}
        locale={locale}
        isReversed={index % 2 !== 0}
      />
    ))}
  </div>

  {experiencesPage?.finalCta && (
    <ExpCTA
      title={experiencesPage.finalCta.title}
      description={experiencesPage.finalCta.description}
      btnText={experiencesPage.finalCta.buttonLabel}
      href={experiencesPage.finalCta.buttonLink || navigation.sites(locale)}
    />
  )}
</BaseLayout>

<style>
  .experiences-intro {
    background-color: var(--color-surface);
  }
  .max-w-700 {
    max-width: 700px;
    margin: 0 auto;
  }
</style>