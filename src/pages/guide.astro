---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroPage from "@/components/main/hero/HeroPage.astro";
import GuideIntro from "@/components/guide/GuideIntro.astro";
import GuideHistory from "@/components/guide/GuideHistory.astro";
import GuideFishingRefuge from "@/components/guide/GuideFishingRefuge.astro";
import GuideProtectedArea from "@/components/guide/GuideProtectedArea.astro";
import GuideInfluenceArea from "@/components/guide/GuideInfluenceArea.astro";
import GuideRecommendations from "@/components/guide/GuideRecommendations.astro";
import GuideDirections from "@/components/guide/GuideDirections.astro";
import GuideAmenities from "@/components/guide/GuideAmenities.astro";
import GuideTouristMap from "@/components/guide/GuideTouristMap.astro";
import ExpCTA from "@/components/main/experiences/ExpCTA.astro";

import { useTranslations } from "@/i18n/utils";
import { getGuidePageWithFallback } from "@/lib/cms";
import {
  heroData as fallbackHero,
  introData as fallbackIntro,
  historyData as fallbackHistory,
  fishingData as fallbackFishing,
  protectedAreaData as fallbackProtected,
  influenceData as fallbackInfluence,
  recommendationsData as fallbackRecommendations,
  directionsData as fallbackDirections,
  amenitiesData as fallbackAmenities,
  touristMapData as fallbackTouristMap,
  ctaData as fallbackCta,
} from "@/data/guideData";
import { navigation } from "@/utils/navigation";

const locale = Astro.currentLocale || "es";
const t = useTranslations(locale);

const guide = await getGuidePageWithFallback(locale);

// Pick CMS data if present, otherwise fall back to the dev seed.
const hero = guide.hero
  ? { title: { es: guide.hero.title, en: guide.hero.title }, desc: { es: guide.hero.desc, en: guide.hero.desc }, image: guide.hero.image }
  : fallbackHero;

const introData = guide.intro
  ? {
      ranchTitle: { es: guide.intro.ranchTitle, en: guide.intro.ranchTitle },
      ranchText: { es: guide.intro.ranchText, en: guide.intro.ranchText },
      portTitle: { es: guide.intro.portTitle, en: guide.intro.portTitle },
      portText: { es: guide.intro.portText, en: guide.intro.portText },
    }
  : fallbackIntro;

const historyData = guide.history
  ? {
      title: { es: guide.history.title, en: guide.history.title },
      text: { es: guide.history.text, en: guide.history.text },
      milestones: guide.history.milestones,
    }
  : fallbackHistory;

const fishingData = guide.fishing
  ? {
      title: { es: guide.fishing.title, en: guide.fishing.title },
      text: { es: guide.fishing.text, en: guide.fishing.text },
      rules: { es: guide.fishing.rules, en: guide.fishing.rules },
    }
  : fallbackFishing;

const protectedAreaData = guide.protected
  ? {
      title: { es: guide.protected.title, en: guide.protected.title },
      text: { es: guide.protected.text, en: guide.protected.text },
      link: {
        label: { es: guide.protected.linkLabel, en: guide.protected.linkLabel },
        href: guide.protected.linkHref,
      },
    }
  : fallbackProtected;

const influenceData = guide.influence
  ? { title: { es: guide.influence.title, en: guide.influence.title }, text: { es: guide.influence.text, en: guide.influence.text } }
  : fallbackInfluence;

const recommendationsData = guide.recommendations
  ? {
      title: { es: guide.recommendations.title, en: guide.recommendations.title },
      items: { es: guide.recommendations.items, en: guide.recommendations.items },
    }
  : fallbackRecommendations;

const directionsData = guide.directions
  ? {
      title: { es: guide.directions.title, en: guide.directions.title },
      loreto: {
        label: { es: guide.directions.loreto.label, en: guide.directions.loreto.label },
        desc: { es: guide.directions.loreto.desc, en: guide.directions.loreto.desc },
        distance: guide.directions.loreto.distance,
        time: guide.directions.loreto.time,
        image: guide.directions.loreto.image,
      },
      laPaz: {
        label: { es: guide.directions.laPaz.label, en: guide.directions.laPaz.label },
        desc: { es: guide.directions.laPaz.desc, en: guide.directions.laPaz.desc },
        distance: guide.directions.laPaz.distance,
        time: guide.directions.laPaz.time,
        image: guide.directions.laPaz.image,
      },
      drivingTipsTitle: { es: guide.directions.drivingTipsTitle, en: guide.directions.drivingTipsTitle },
      drivingTips: { es: guide.directions.drivingTips, en: guide.directions.drivingTips },
    }
  : fallbackDirections;

const amenitiesData = guide.amenities
  ? {
      title: { es: guide.amenities.title, en: guide.amenities.title },
      items: guide.amenities.items.map((a) => ({
        icon: a.icon as 'wifi' | 'signal' | 'toilet' | 'parking' | 'water',
        title: { es: a.title, en: a.title },
        text: { es: a.text, en: a.text },
      })),
    }
  : fallbackAmenities;

const touristMapData = guide.touristMap
  ? {
      title: { es: guide.touristMap.title, en: guide.touristMap.title },
      image: guide.touristMap.image,
      caption: { es: guide.touristMap.caption, en: guide.touristMap.caption },
    }
  : fallbackTouristMap;
---

<BaseLayout
  siteTitle={t("page.guide.siteTitle")}
  ogTitle={t("page.guide.ogTitle")}
  siteDescription={t("page.guide.siteDescription")}
  ogDescription={t("page.guide.ogDescription")}
>
  <HeroPage
    slot="Hero"
    title={t("guidePage.hero.title")}
    description={t("guidePage.hero.desc")}
    backgroundImage={hero.image}
  />

  <GuideIntro data={introData} locale={locale} />

  <GuideHistory data={historyData} locale={locale} />

  <GuideFishingRefuge data={fishingData} locale={locale} />

  <GuideProtectedArea data={protectedAreaData} locale={locale} />

  <GuideInfluenceArea data={influenceData} locale={locale} />

  <GuideRecommendations data={recommendationsData} locale={locale} />

  <GuideDirections data={directionsData} locale={locale} />

  <GuideAmenities data={amenitiesData} locale={locale} />

  <GuideTouristMap data={touristMapData} locale={locale} />

  <ExpCTA
    title={guide.cta ? t("guidePage.cta.title") : t("guidePage.cta.title")}
    description={guide.cta ? t("guidePage.cta.desc") : t("guidePage.cta.desc")}
    btnText={t("guidePage.cta.btn")}
    href={navigation.experiences(locale)}
  />
</BaseLayout>
