---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MapSection from "@/components/main/mapSection/MapSection.astro";
import CtaSection from "@/components/main/CTA/CtaSection.astro";
import { useTranslations } from "@/i18n/utils";

const t = useTranslations(Astro.currentLocale);
---

<BaseLayout siteTitle={t("page.sites.siteTitle")} ogTitle={t("page.sites.ogTitle")} siteDescription={t("page.sites.siteDescription")} ogDescription={t("page.sites.ogDescription")}>
  <h2>{t("page.sites.ogTitle")}</h2>
  <p>{t("page.sites.siteDescription")}</p>
  <slot />
  <MapSection />
  <CtaSection />
</BaseLayout>
