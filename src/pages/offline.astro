---
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations } from "@/i18n/utils";

const t = useTranslations(Astro.currentLocale);
---

<BaseLayout
  title={`${t('offline.title')} | Puerto Agua Verde`}
  siteTitle="Sin conexión - Puerto Agua Verde"
  siteDescription="Esta página no está disponible sin conexión a internet"
>
  <section class="offline-page section-padding container">
    <div class="offline-content">
      <div class="offline-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="1" y1="1" x2="23" y2="23"></line>
          <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"></path>
          <path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"></path>
          <path d="M10.71 5.05A16 16 0 0 1 22.58 9"></path>
          <path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"></path>
          <path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path>
          <line x1="12" y1="20" x2="12.01" y2="20"></line>
        </svg>
      </div>
      <h1>{t('offline.title')}</h1>
      <p>{t('offline.message')}</p>
      <div class="offline-actions">
        <button id="retry-btn" class="btn btn-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"></polyline>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
          </svg>
          {t('offline.retry')}
        </button>
        <a href="/" class="btn btn-outline">{t('offline.home')}</a>
      </div>
      <div class="offline-tip">
        <p><strong>{t('offline.tipTitle')}</strong></p>
        <p>{t('offline.tipText')}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .offline-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .offline-content {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .offline-icon {
    margin-bottom: var(--space-md);
    color: var(--color-primary);
  }

  .offline-content h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
  }

  .offline-content > p {
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-lg);
  }

  .offline-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .offline-actions .btn {
    min-width: 140px;
  }

  .offline-tip {
    background-color: var(--color-surface);
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    text-align: left;
  }

  .offline-tip p {
    font-size: var(--text-sm);
    color: var(--color-on-surface-variant);
  }

  .offline-tip p:first-child {
    color: var(--color-on-surface);
    margin-bottom: var(--space-xs);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const retryBtn = document.getElementById('retry-btn');
    if (retryBtn) {
      retryBtn.addEventListener('click', () => {
        window.location.reload();
      });
    }
  });

  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.ready.then((registration) => {
      if (registration.active) {
        registration.active.postMessage({
          type: 'SKIP_WAITING'
        });
      }
    });
  }
</script>
