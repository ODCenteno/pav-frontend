---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SiteHero from "../../../components/site-detail/SiteHero.astro";
import SiteSummary from "../../../components/site-detail/SiteSummary.astro";
import SiteInfoPanel from "../../../components/site-detail/SiteInfoPanel.astro";
import SiteTips from "../../../components/site-detail/SiteTips.astro";
import SiteGallery from "../../../components/site-detail/SiteGallery.astro";
import RelatedSites from "../../../components/site-detail/RelatedSites.astro";
import MemberStrip from "../../../components/site-detail/MemberStrip.astro";
import StoryTimeline from "../../../components/site-detail/StoryTimeline.astro";
import ProductList from "../../../components/site-detail/ProductList.astro";
import SocialLinks from "../../../components/site-detail/SocialLinks.astro";
import ExpCTA from "@/components/main/experiences/ExpCTA.astro";
import StickyActionBar from "../../../components/site-detail/StickyActionBar.tsx";
import { useTranslations } from "../../../i18n/utils";
import { getListingsWithFallback } from "../../../lib/cms";
import type { Listing } from "../../../types/listing.type";
import { navigation } from "@/utils/navigation";

export const prerender = true;

export async function getStaticPaths() {
  const listings = await getListingsWithFallback("en");
  return listings.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: Listing;
}

const { item } = Astro.props;
const locale = "en";
const t = useTranslations(locale);

const title = item.name[locale];
const description = item.description?.[locale];
const categoryLabel = item.category?.name?.[locale] || "";
const tags = (item.tags || []).map(tag => tag[locale]);
const location = item.location;
const categoryColor = item.category?.color || "#68a299";

const labels = {
  about: t("siteDetailPage.labels.about"),
  directions: t("siteDetailPage.actions.directions"),
  contact: t("siteDetailPage.actions.contact"),
  favorite: t("siteDetailPage.actions.favorite"),
  favoriteActive: t("siteDetailPage.actions.favoriteActive"),
  share: t("siteDetailPage.actions.share"),
  info: t("siteDetailPage.labels.info"),
  hours: t("siteDetailPage.labels.hours"),
  price: t("siteDetailPage.labels.price"),
  amenities: t("siteDetailPage.labels.amenities"),
  tips: t("siteDetailPage.labels.tips"),
  gallery: t("siteDetailPage.labels.gallery") || "Gallery",
  related: t("siteDetailPage.labels.related") || "Related Sites",
  behind: t("siteDetailPage.labels.behind"),
  stories: t("siteDetailPage.labels.stories"),
  products: t("siteDetailPage.labels.products"),
  follow: t("siteDetailPage.labels.follow"),
};

const contactActions = {
  whatsapp: item.contact?.whatsapp,
  phone: item.contact?.phone,
};

const schedule = item.schedule?.text?.[locale];
const amenities = (item.amenities || []).map(a => a[locale]);
const bestTime = item.recommendations?.bestTimeToVisit?.[locale];
const bring = (item.recommendations?.whatToBring || []).map(b => b[locale]);
const accessibility = item.recommendations?.accessibilityNotes?.[locale];
const connectivity = item.recommendations?.connectivityNotes?.[locale];
---

<BaseLayout
  siteTitle={`${title} | Puerto Agua Verde`}
  siteDescription={description}
>
  <SiteHero
    slot="Hero"
    id={item.id}
    title={title}
    categoryLabel={categoryLabel}
    image={item.media?.mainImageUrl || ""}
    tags={tags}
    labels={labels}
  />

  <SiteSummary
    description={description}
    labels={labels}
    contactActions={contactActions}
    location={location}
    categoryColor={categoryColor}
  >
    <SiteGallery
      title={labels.gallery}
      images={item.media?.galleryUrls || []}
      noContainer={true}
    />
  </SiteSummary>

  {item.members && item.members.length > 0 && (
    <MemberStrip title={labels.behind} members={item.members} />
  )}

  <SiteInfoPanel
    labels={labels}
    schedule={schedule}
    price={item.pricing?.price}
    amenities={amenities}
  />

  {item.social && item.social.length > 0 && (
    <section class="container site-social">
      <SocialLinks title={labels.follow} social={item.social} />
    </section>
  )}

  {item.stories && item.stories.length > 0 && (
    <StoryTimeline title={labels.stories} stories={item.stories} />
  )}

  {item.products && item.products.length > 0 && (
    <ProductList title={labels.products} products={item.products} />
  )}

  {(bestTime || (bring && bring.length > 0) || accessibility || connectivity) && (
    <SiteTips
      labels={labels}
      bestTime={bestTime}
      whatToBring={bring}
      accessibility={accessibility}
      connectivity={connectivity}
    />
  )}

  <RelatedSites
    title={labels.related}
    relatedIds={item.relatedSites}
    currentLang={locale}
  />

  <ExpCTA
    title={t("siteDetailPage.cta.title")}
    description={t("siteDetailPage.cta.desc")}
    btnText={t("siteDetailPage.cta.btn")}
    href={navigation.sites(locale)}
  />

  <StickyActionBar
    client:load
    id={item.id}
    whatsapp={item.contact?.whatsapp}
    lat= {item.location?.lat}
    lng= {item.location?.lng}
    labels={{
      directions: labels.directions,
      contact: labels.contact,
      favorite: labels.favorite,
      favoriteActive: labels.favoriteActive,
    }}
  />
</BaseLayout>
