---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroPage from "@/components/main/hero/HeroPage.astro";
import AboutIntro from "@/components/about/AboutIntro.astro";
import AboutValues from "@/components/about/AboutValues.astro";
import TeamGrid from "@/components/about/TeamGrid.astro";
import OrganizationsGrid from "@/components/about/OrganizationsGrid.astro";
import CommunityMessage from "@/components/about/CommunityMessage.astro";
import CollaborationBlock from "@/components/about/CollaborationBlock.astro";
import ExpCTA from "@/components/main/experiences/ExpCTA.astro";

import { useTranslations } from "@/i18n/utils";
import { 
  introData, 
  valuesData, 
  teamData, 
  organizationsData, 
  communityMessageData, 
  collaborationData 
} from "@/data/aboutData";
import { navigation } from "@/utils/navigation";

const locale = "en";
const t = useTranslations(locale);
---

<BaseLayout 
  siteTitle={t("about.siteTitle")} 
  ogTitle={t("about.ogTitle")}
  siteDescription={t("about.siteDescription")}
  ogDescription={t("about.ogDescription")}
>
  <HeroPage 
    slot="Hero" 
    title={t("aboutPage.hero.title")} 
    description={t("aboutPage.hero.description")}
    backgroundImage={t("aboutPage.hero.image")}
  />
  
  <AboutIntro data={introData} locale={locale} />
  
  <AboutValues {...valuesData} locale={locale} />
  
  <TeamGrid team={teamData} locale={locale} />
  
  <OrganizationsGrid organizations={organizationsData} locale={locale} />
  
  <CommunityMessage data={communityMessageData} locale={locale} />
  
  <CollaborationBlock data={collaborationData} locale={locale} />

  <ExpCTA 
    title={t("aboutPage.cta.title")} 
    description={t("aboutPage.cta.desc")} 
    btnText={t("aboutPage.cta.btn")} 
    href={navigation.sites(locale)} 
  />
</BaseLayout>
