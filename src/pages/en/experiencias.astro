---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MapSection from "@/components/main/mapSection/MapSection.astro";
import CtaSection from "@/components/main/CTA/CtaSection.astro";
import { useTranslations } from "@/i18n/utils";

const t = useTranslations(Astro.currentLocale);
---

<BaseLayout siteTitle={t("page.experiences.siteTitle")} ogTitle={t("page.experiences.ogTitle")} siteDescription={t("page.experiences.siteDescription")} ogDescription={t("page.experiences.ogDescription")}>
  <slot />
  <MapSection />
  <CtaSection />
</BaseLayout>
