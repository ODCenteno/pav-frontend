---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ExpHero from "../../components/main/experiences/ExpHero.astro";
import ExpIntro from "../../components/main/experiences/ExpIntro.astro";
import ExpFeatured from "../../components/main/experiences/ExpFeatured.astro";
import ExpGrid from "../../components/main/experiences/ExpGrid.astro";
import ExpCTA from "../../components/main/experiences/ExpCTA.astro";
import PopupManager from "../../components/popup/PopupManager.astro";
import { useTranslations } from "../../i18n/utils";
import { categoryData } from "../../data/categoryData";
import type { Listing } from "../../types/listing.type";

const locale = "en";
const t = useTranslations(locale);

// Filter experiences from data
const allExperiences = categoryData.filter(item => item.categoryId === "experiences") as unknown as Listing[];
const featuredExperiences = allExperiences.filter(item => item.isFeatured);
const regularExperiences = allExperiences.filter(item => !item.isFeatured);
---

<BaseLayout
  siteTitle={t("page.experiences.siteTitle")}
  ogTitle={t("page.experiences.ogTitle")}
  siteDescription={t("page.experiences.siteDescription")}
  ogDescription={t("page.experiences.ogDescription")}
>
  <ExpHero 
    slot="Hero"
    title={t("experiencesPage.heroTitle")} 
    description={t("experiencesPage.heroDesc")} 
  />

  <ExpIntro text={t("experiencesPage.intro")} />

  {featuredExperiences.map((exp, index) => (
    <ExpFeatured 
      experience={exp} 
      locale={locale} 
      isReversed={index % 2 !== 0} 
    />
  ))}

  {regularExperiences.length > 0 && (
    <ExpGrid 
      title={t("experiencesPage.featuredTitle")} 
      experiences={regularExperiences} 
      locale={locale} 
    />
  )}

  <ExpCTA 
    title={t("experiencesPage.cta.title")} 
    description={t("experiencesPage.cta.desc")} 
    btnText={t("experiencesPage.cta.btn")} 
    href="/en/sitios" 
  />

  <PopupManager />
</BaseLayout>
