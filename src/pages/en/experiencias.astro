---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/main/hero/PageHero.astro";
import ExpFeatured from "@/components/main/experiences/ExpFeatured.astro";
import ExpCTA from "@/components/main/experiences/ExpCTA.astro";
import { useTranslations } from "@/i18n/utils";
import { categoryData } from "@/data/categoryData";
import { navigation } from "@/utils/navigation";

const locale = "en";
const t = useTranslations(locale);

// Get a few featured experiences
const featuredExperiences = categoryData
  .filter(item => item.categoryId === 'experiences')
  .slice(0, 3);
---

<BaseLayout 
  siteTitle={t("experiences.siteTitle")} 
  ogTitle={t("experiences.ogTitle")}
  siteDescription={t("experiences.siteDescription")}
  ogDescription={t("experiences.ogDescription")}
>
  <PageHero 
    slot="Hero"
    title={t("experiencesPage.heroTitle")} 
    description={t("experiencesPage.heroDesc")}
  />

  <section class="experiences-intro section-padding">
    <div class="container text-center">
      <h2>{t("experiencesPage.introTitle")}</h2>
      <p class="max-w-700">{t("experiencesPage.introDesc")}</p>
    </div>
  </section>

  <div class="experiences-list">
    {featuredExperiences.map((exp, index) => (
      <ExpFeatured 
        experience={exp} 
        locale={locale} 
        isReversed={index % 2 !== 0} 
      />
    ))}
  </div>

  <ExpCTA 
    title={t("experiencesPage.ctaTitle")} 
    description={t("experiencesPage.ctaDesc")}
    btnText={t("experiencesPage.ctaBtn")}
    href={navigation.sites(locale)}
  />
</BaseLayout>

<style>
  .experiences-intro {
    background-color: var(--color-surface);
  }
  .max-w-700 {
    max-width: 700px;
    margin: 0 auto;
  }
</style>
