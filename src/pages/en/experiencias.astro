---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/main/hero/PageHero.astro";
import CardMain from "../../components/cards/CardMain.astro";
import PopupManager from "../../components/popup/PopupManager.astro";
import { useTranslations } from "../../i18n/utils";
import { categoryData } from "../../data/categoryData";
import type { Listing } from "../../types/listing.type";

const locale = "en";
const t = useTranslations(locale);

// Filter experiences from data
const experiences = categoryData.filter(item => item.categoryId === "experiences") as unknown as Listing[];
---

<BaseLayout
  siteTitle={t("page.experiences.siteTitle")}
  ogTitle={t("page.experiences.ogTitle")}
  siteDescription={t("page.experiences.siteDescription")}
  ogDescription={t("page.experiences.ogDescription")}
>
  <PageHero 
    slot="Hero"
    title={t("featured.experiences.title")} 
    description={t("featured.experiences.desc")} 
  />

  <section class="section-padding">
    <div class="container">
      <div class="experiences-grid">
        {experiences.map((item) => (
          <CardMain item={item} currentLang={locale} />
        ))}
      </div>
    </div>
  </section>

  <PopupManager />
</BaseLayout>

<style>
  .experiences-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .experiences-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .experiences-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
