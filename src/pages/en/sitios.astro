---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/main/hero/PageHero.astro";
import FavoritesSection from "@/components/main/favorites/FavoritesSection.astro";
import CardMain from "@/components/cards/CardMain.astro";
import ExpCTA from "@/components/main/experiences/ExpCTA.astro";

import SitesExplorer from "@/components/main/categories/SitesExplorer.tsx";
import { useTranslations } from "@/i18n/utils";
import { categoryData } from "@/data/categoryData";
import type { Listing } from "@/types/listing.type";

const locale = "en";
const t = useTranslations(locale);

// Group data by category
const categories = [
  { id: "sites", label: t("sitesPage.filters.beaches") },
  { id: "restaurants", label: t("sitesPage.filters.food") },
  { id: "accommodation", label: t("sitesPage.filters.stay") },
  { id: "services", label: t("sitesPage.filters.services") },
  { id: "experiences", label: t("nav.experiences") },
];

const groupedSites = categories
  .map((cat) => ({
    ...cat,
    items: categoryData
      .filter((item) => item.categoryId === cat.id)
      .map((item) => ({
        ...item,
        // Adapt flat fields to localized objects
        name: { es: item.name_es, en: item.name_en },
        shortDescription: { es: item.description_es, en: item.description_en },
        description: { es: item.description_es, en: item.description_en },
        // Convert arrays of strings to array of LocalizedStrings
        tags: (item.tags_es || []).map((tag, i) => ({
          es: tag,
          en: item.tags_en?.[i] || tag,
        })),
        media: {
          mainImageUrl: item.image,
        },
        pricing: {
          price: item.price,
        },
      })) as unknown as Listing[],
  }))
  .filter((group) => group.items.length > 0);
---

<BaseLayout siteTitle={t("sites.siteTitle")} ogTitle={t("sites.ogTitle")} siteDescription={t("sites.siteDescription")} ogDescription={t("sites.ogDescription")}>
  <PageHero slot="Hero" title={t("sitesPage.heroTitle")} description={t("sitesPage.heroDesc")} />

  <FavoritesSection />

  <section class="sites-explorer section-padding">
    <div class="container">
      <SitesExplorer
        client:load
        locale={locale}
        categories={categories}
        translations={{
          all: t("categories.all"),
          noResults: t("sitesPage.empty"),
          searchPlaceholder: t("sitesPage.searchPlaceholder"),
        }}
      />

      <!-- Categories Sections -->
      {
        groupedSites.map((group) => (
          <div class="category-section" id={`category-${group.id}`}>
            <div class="category-header">
              <h2 class="category-title">{group.label}</h2>
              <span class="item-count">
                {group.items.length} {locale === "es" ? "sitios" : "places"}
              </span>
            </div>

            <div class="horizontal-carousel">
              {group.items.map((item) => (
                <div class="carousel-item">
                  <CardMain item={item} currentLang={locale} />
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <ExpCTA title={t("aboutPage.cta.title")} description={t("aboutPage.cta.desc")} btnText={t("aboutPage.cta.btn")} href="/en/acerca" />
</BaseLayout>

<style>
  .sites-explorer {
    background-color: var(--color-surface);
  }

  .category-section {
    margin-bottom: var(--space-2xl);
  }

  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-md);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: var(--space-xs);
  }

  .category-title {
    font-size: var(--text-2xl);
    margin: 0;
  }

  .item-count {
    font-size: var(--text-xs);
    color: var(--secondary-text);
    font-weight: 600;
    text-transform: uppercase;
  }

  .horizontal-carousel {
    display: flex;
    gap: var(--space-md);
    overflow-x: auto;
    padding-bottom: var(--space-md);
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE 10+ */
    -webkit-overflow-scrolling: touch;
  }

  .horizontal-carousel::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .carousel-item {
    flex: 0 0 280px;
    scroll-snap-align: start;
  }

  @media (min-width: 768px) {
    .carousel-item {
      flex: 0 0 320px;
    }
  }
</style>
