---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/main/hero/Hero.astro";
import PopupManager from "@/components/popup/PopupManager.astro";
import Destinations from "../../components/main/destinations/Destinations.astro";
import Highlights from "../../components/main/highlights/Highlights.astro";
import QuickFacts from "../../components/main/quickFacts/QuickFacts.astro";
import MapSection from "../../components/main/mapSection/MapSection.astro";
import CtaSection from "@/components/main/CTA/CtaSection.astro";
import { useTranslations } from "@/i18n/utils";
import { getHomepageWithFallback } from "@/lib/cms";

const locale = Astro.currentLocale || "es";
const t = useTranslations(locale);
const homepage = await getHomepageWithFallback(locale);
---

<BaseLayout siteTitle={t("page.index.siteTitle")} ogTitle={t("page.index.ogTitle")} siteDescription={t("page.index.siteDescription")} ogDescription={t("page.index.ogDescription")}>
  <Hero slot="Hero" data={homepage.hero} />
  <PopupManager slot="categories" />
  <Destinations header={homepage.destinations.header} items={homepage.destinations.items} />
  <Highlights header={homepage.highlights.header} items={homepage.highlights.items} />
  <QuickFacts header={homepage.quickFacts.header} items={homepage.quickFacts.items} images={homepage.quickFacts.images} />
  <MapSection data={homepage.mapSection} />
  <CtaSection data={homepage.finalCta} />
</BaseLayout>