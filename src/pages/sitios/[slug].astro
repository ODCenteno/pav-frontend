---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHero from "../../components/site-detail/SiteHero.astro";
import SiteSummary from "../../components/site-detail/SiteSummary.astro";
import SiteInfoPanel from "../../components/site-detail/SiteInfoPanel.astro";
import SiteTips from "../../components/site-detail/SiteTips.astro";
import SiteGallery from "../../components/site-detail/SiteGallery.astro";
import RelatedSites from "../../components/site-detail/RelatedSites.astro";
import StickyActionBar from "../../components/site-detail/StickyActionBar.tsx";
import { useTranslations } from "../../i18n/utils";
import { categoryData } from "../../data/categoryData";
import type { Listing } from "../../types/listing.type";
import ExpCTA from "@/components/main/experiences/ExpCTA.astro";
import { navigation } from "@/utils/navigation";

export const prerender = true;

export async function getStaticPaths() {
  const listings = categoryData;
  return listings.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const locale = "es";
const t = useTranslations(locale);

const title = item.name_es || item.name?.[locale] || item.name?.es;
const description = item.description_es || item.description?.[locale] || item.description?.es;
const categoryLabel = item.category_name_es || item.category?.name?.[locale] || item.category?.name?.es;
const tags = item.tags_es || (Array.isArray(item.tags) ? item.tags.map((t) => (typeof t === "string" ? t : t?.[locale] || t?.es)) : []);

const labels = {
  about: t("siteDetailPage.labels.about"),
  directions: t("siteDetailPage.actions.directions"),
  contact: t("siteDetailPage.actions.contact"),
  favorite: t("siteDetailPage.actions.favorite"),
  favoriteActive: t("siteDetailPage.actions.favoriteActive"),
  share: t("siteDetailPage.actions.share"),
  info: t("siteDetailPage.labels.info"),
  hours: t("siteDetailPage.labels.hours"),
  price: t("siteDetailPage.labels.price"),
  amenities: t("siteDetailPage.labels.amenities"),
  tips: t("siteDetailPage.labels.tips"),
};

const contactActions = {
  whatsapp: item.contact?.whatsapp,
  phone: item.contact?.phone,
};

const schedule = item.schedule?.text_es || item.schedule?.text?.[locale] || item.schedule?.text?.es;
const amenities = item.amenities_es || (Array.isArray(item.amenities) ? item.amenities.map((a) => (typeof a === "string" ? a : a?.[locale] || a?.es)) : []);
const bestTime = item.recommendations?.bestTime_es || item.recommendations?.bestTimeToVisit?.[locale] || item.recommendations?.bestTimeToVisit?.es;
const bring = item.recommendations?.bring_es || (Array.isArray(item.recommendations?.whatToBring) ? item.recommendations.whatToBring.map((b) => (typeof b === "string" ? b : b?.[locale] || b?.es)) : []);
---

<BaseLayout siteTitle={`${title} | Puerto Agua Verde`} siteDescription={description}>
  <SiteHero slot="Hero" id={item.id} title={title} categoryLabel={categoryLabel} image={item.image} tags={tags} labels={labels} />

  <SiteSummary description={description} labels={labels} contactActions={contactActions}>
    <SiteGallery title={labels.gallery} images={item.gallery} noContainer={true} />
  </SiteSummary>

  <SiteInfoPanel labels={labels} schedule={schedule} price={item.price} amenities={amenities} />

  {(bestTime || (bring && bring.length > 0)) && <SiteTips labels={labels} bestTime={bestTime} whatToBring={bring} />}

  <RelatedSites title={labels.related} relatedIds={item.relatedSites} currentLang={locale} />

  <ExpCTA title={t("siteDetailPage.cta.title")} description={t("siteDetailPage.cta.desc")} btnText={t("siteDetailPage.cta.btn")} href={navigation.sites(locale)} />

  <StickyActionBar
    client:load
    id={item.id}
    lat={item.location.lat}
    lng={item.location.lng}
    whatsapp={item.contact?.whatsapp}
    labels={{
      directions: labels.directions,
      contact: labels.contact,
      favorite: labels.favorite,
      favoriteActive: labels.favoriteActive,
    }}
  />
</BaseLayout>
